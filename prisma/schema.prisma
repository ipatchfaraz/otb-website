// Prisma schema for the OTB CMS + lead-magnet mailing list.
// Generated to Postgres — Vercel Postgres (Neon) recommended.
// After setting DATABASE_URL, run: `npx prisma db push` (dev)
// or `npx prisma migrate deploy` (production).

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  slug         String   @id
  order        Int      @default(0)
  discipline   String
  line         String
  tags         String[] // ["STRATEGY", "IDENTITY", "PACKAGING"]
  coverImage   String   // work-grid cover URL (absolute or /images/... path)

  // Case study fields
  caseLabel    String
  title        String
  client       String
  tagline      String
  sector       String
  scope        String
  year         String
  brief        String   @db.Text
  problemHead  String   @db.Text
  problemBody  String   @db.Text
  digBody      String   @db.Text
  insight      String   @db.Text
  leapHead     String   @db.Text
  leapBody     String   @db.Text
  solutionBody String   @db.Text
  payoff       String   @db.Text
  heroImg      String
  gallery      Json?    // Gallery[] — see lib/case-studies.ts

  published    Boolean  @default(true)
  // True on projects that show in the homepage FEATURED WORK strip.
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([published, order])
  @@index([featured, order])
}

model JournalEntry {
  log       String   @id // "01", "02", ...
  slug      String   @unique
  category  String
  readMin   String   // "6 MIN READ"
  date      String   // "2026.02.11" — kept as string for prototype fidelity
  author    String
  authorRole String
  thumb     String?
  title     String
  dek       String   @db.Text
  body      Json     // Block[] { t: 'p'|'h'|'quote'|'list', v: string | string[] }
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

// Small key/value store for site-wide config the admin can change
// without a code deploy. Currently holds favicon_url.
model SiteConfig {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model Lead {
  id             String    @id @default(cuid())
  email          String    @unique
  // Where in the site the form was submitted: 'popup', 'teaser', or a
  // legacy 'kit-download' for rows captured before the split.
  source         String    @default("kit-download")
  // Vercel geo headers (ISO country code, city name). Nullable because
  // dev / non-Vercel traffic won't have them.
  country        String?
  city           String?
  // Traffic-source category derived from document.referrer:
  // 'instagram' | 'google' | 'facebook' | 'twitter' | 'tiktok' |
  // 'linkedin' | 'whatsapp' | 'telegram' | 'direct' | 'other'.
  // Raw referrer URL kept alongside for detail.
  referrer       String?
  referrerRaw    String?
  // When (if ever) the user actually clicked DOWNLOAD KIT after
  // submitting the form. Null = form-only lead; a date = confirmed
  // download.
  downloadedAt   DateTime?
  createdAt      DateTime  @default(now())
  resendSyncedAt DateTime?
  resendError    String?
}
