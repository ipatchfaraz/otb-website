# Copy to .env.local for dev, or add these in the Vercel dashboard for prod.
# See DEPLOY.md for step-by-step setup.

# Postgres (Vercel Postgres / Neon).
# Vercel auto-injects this when you attach the DB to the project.
DATABASE_URL=

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Auto-set by Vercel to the deploy URL; only set locally.
NEXTAUTH_URL=http://localhost:3000

# Admin bootstrap. First login attempt matching these seeds the first
# AdminUser row. After that, change the password via a follow-up UI or
# by running: npx bcryptjs hash-password '<new-password>' and updating
# the DB row directly.
ADMIN_EMAIL=outtatheboxhq@gmail.com
# Bcrypt hash. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 10))" 'YOUR-PASSWORD'
ADMIN_PASSWORD_HASH=

# Resend (lead-magnet mailing list).
# Sign up at resend.com — free tier is 3k emails/mo.
# 1. Create an API key. 2. Create an Audience. 3. Paste the IDs below.
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
